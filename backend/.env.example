# Port du serveur Express
PORT=4000

# Origine autorisée pour le CORS (URL du front en dev)
CORS_ORIGIN=*

# Supabase — récupère ces valeurs dans : Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# Clé service_role (NE JAMAIS exposer côté front, garde-la uniquement ici)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
